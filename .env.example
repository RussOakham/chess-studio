# Root environment variables
# These are shared across all packages/apps

# Node Environment
NODE_ENV=development

# Secrets Management (Doppler)
# DOPPLER_TOKEN=your_doppler_token_here

# Better Auth (set in Convex, Doppler, and .env.local; use same value everywhere)
# Generate: openssl rand -base64 32
# BETTER_AUTH_SECRET=

# Convex (apps/web) - set after running: npx convex dev --once --configure=new
# CONVEX_DEPLOYMENT=dev:xxx
# NEXT_PUBLIC_CONVEX_URL=https://xxx.convex.cloud
# NEXT_PUBLIC_CONVEX_SITE_URL=https://xxx.convex.site  # required for Better Auth Convex integration
# NEXT_PUBLIC_SITE_URL=http://localhost:3000     
# SITE_URL=http://localhost:3000     # Required by Better Auth Convex integration

# GitHub OAuth (Better Auth social provider)
# Create an OAuth App: https://github.com/settings/developers — callback URL:
# http://localhost:3000/api/auth/callback/github (production: https://<your-domain>/api/auth/callback/github)
#
# You need BOTH:
# (1) apps/web/.env.local — so Next.js can show the GitHub button (and match isGithubOAuthEnvConfigured)
# (2) Convex deployment env — auth runs on Convex; without this you get PROVIDER_NOT_FOUND on sign-in:
#     npx convex env set GITHUB_CLIENT_ID "<from GitHub OAuth app>"
#     npx convex env set GITHUB_CLIENT_SECRET "<from GitHub OAuth app>"
#     (or Convex Dashboard → Settings → Environment Variables for the same deployment)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Optional: force-show GitHub button without server env (e.g. edge cases)
# NEXT_PUBLIC_GITHUB_AUTH_ENABLED=true
