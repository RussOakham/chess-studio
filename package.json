{
  "name": "chess-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "concurrently --names \"next,convex\" \"pnpm run dev\" \"pnpm --filter @repo/web run convex:dev\"",
    "build": "turbo run build",
    "vercel-build:web": "turbo run vercel-build --filter=@repo/web",
    "lint": "oxlint --type-aware --type-check . && eslint .",
    "lint:fix": "oxlint --type-aware --type-check --fix . && eslint --fix .",
    "lint:md": "markdownlint '**/*.md' --ignore .markdownlintignore",
    "lint:md:fix": "markdownlint '**/*.md' --ignore .markdownlintignore --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "prep": "pnpm format:fix && pnpm lint && pnpm type-check && pnpm test",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@typescript-eslint/parser": "8.59.0",
    "@typescript/native-preview": "7.0.0-dev.20260403.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-oxlint": "^1.61.0",
    "eslint-plugin-yml": "^1.19.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,md}": [
      "oxlint --type-aware --type-check",
      "eslint",
      "oxfmt"
    ],
    "*.{json,yml,yaml}": [
      "eslint --ignore-pattern pnpm-lock.yaml"
    ],
    "*.md": [
      "markdownlint",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "catalog": {
      "@typescript-eslint/eslint-plugin": "8.59.0",
      "@typescript-eslint/parser": "8.59.0",
      "eslint": "10.2.1",
      "eslint-plugin-json": "^4.0.1",
      "eslint-plugin-yml": "^1.19.1",
      "typescript": "6.0.3",
      "@typescript/native-preview": "7.0.0-dev.20260403.1",
      "turbo": "2.9.6",
      "husky": "9.1.7",
      "lint-staged": "16.4.0",
      "markdownlint-cli": "0.48.0",
      "@eslint/js": "10.1.0",
      "next": "16.2.2",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@types/node": "24.12.2",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "tailwindcss": "4.2.2",
      "clsx": "^2.1.1",
      "tailwind-merge": "^2.5.5",
      "lucide-react": "^1.7.0",
      "@radix-ui/react-slot": "^1.1.1",
      "class-variance-authority": "^0.7.1"
    },
    "patchedDependencies": {
      "eslint-plugin-json@4.0.1": "patches/eslint-plugin-json@4.0.1.patch"
    },
    "overrides": {
      "@typescript-eslint/eslint-plugin": "8.59.0",
      "@typescript-eslint/parser": "8.59.0",
      "@typescript-eslint/project-service": "8.59.0",
      "@typescript-eslint/tsconfig-utils": "8.59.0",
      "@typescript-eslint/type-utils": "8.59.0",
      "@typescript-eslint/typescript-estree": "8.59.0",
      "@typescript-eslint/utils": "8.59.0",
      "typescript-eslint": "8.59.0"
    }
  }
}
