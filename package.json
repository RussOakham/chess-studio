{
  "name": "chess-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "concurrently --names \"next,convex\" \"pnpm run dev\" \"pnpm --filter @repo/web run convex:dev\"",
    "build": "turbo run build",
    "vercel-build:web": "turbo run vercel-build --filter=@repo/web",
    "lint": "oxlint --type-aware --type-check . && eslint .",
    "lint:fix": "oxlint --type-aware --type-check --fix . && eslint --fix .",
    "lint:md": "markdownlint '**/*.md' --ignore .markdownlintignore",
    "lint:md:fix": "markdownlint '**/*.md' --ignore .markdownlintignore --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "prep": "pnpm format:fix && pnpm lint && pnpm type-check && pnpm test",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@typescript/native-preview": "7.0.0-dev.20260403.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-oxlint": "^1.58.0",
    "eslint-plugin-yml": "^1.19.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "oxlint --type-aware --type-check",
      "eslint",
      "oxfmt"
    ],
    "*.{json,yml,yaml}": [
      "eslint"
    ],
    "*.md": [
      "markdownlint",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "catalog": {
      "@typescript-eslint/eslint-plugin": "8.52.0",
      "@typescript-eslint/parser": "8.52.0",
      "eslint": "9.39.2",
      "eslint-config-next": "16.2.2",
      "eslint-plugin-react": "7.37.5",
      "eslint-plugin-react-hooks": "7.0.1",
      "eslint-plugin-sonarjs": "^3.0.5",
      "eslint-plugin-unicorn": "^62.0.0",
      "eslint-plugin-jsx-a11y": "^6.10.2",
      "eslint-plugin-json": "^4.0.1",
      "eslint-plugin-yml": "^1.19.1",
      "typescript": "5.9.3",
      "@typescript/native-preview": "7.0.0-dev.20260403.1",
      "turbo": "2.9.3",
      "husky": "9.1.7",
      "lint-staged": "16.4.0",
      "markdownlint-cli": "0.48.0",
      "@eslint/js": "9.39.2",
      "next": "16.2.2",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@types/node": "24.12.2",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "tailwindcss": "4.2.2",
      "clsx": "^2.1.1",
      "tailwind-merge": "^2.5.5",
      "lucide-react": "^0.468.0",
      "@radix-ui/react-slot": "^1.1.1",
      "class-variance-authority": "^0.7.1"
    }
  }
}
