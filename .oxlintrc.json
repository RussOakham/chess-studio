{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist/**",
    "build/**",
    ".next/**",
    ".turbo/**",
    "node_modules/**",
    "**/public/engine/**",
    "**/*.wasm",
    "**/convex/_generated/**"
  ],
  "jsPlugins": ["@convex-dev/eslint-plugin"],
  "plugins": [
    "eslint",
    "unicorn",
    "jsdoc",
    "typescript",
    "jsx-a11y",
    "react",
    "react-perf",
    "oxc",
    "import",
    "nextjs",
    "promise",
    "node",
    "jest",
    "vitest"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn",
    "pedantic": "off",
    "restriction": "off"
  },
  "rules": {
    "unicorn/no-null": "off",
    "unicorn/numeric-separators-style": "off",
    "react-in-jsx-scope": "off",
    "jsx-max-depth": "off",
    "arrow-body-style": "off",
    "func-style": "off",
    "jsx-props-no-spreading": "off",
    "no-magic-numbers": "off",
    "sort-keys": "off",
    "no-ternary": "off",
    "no-named-export": "off",
    "prefer-default-export": "off",
    "no-namespace": "off",
    "sort-imports": "off",
    "img-redundant-alt": "off",
    "jsx-no-jsx-as-prop": "off",
    "jsx-no-new-function-as-prop": "off",
    "no-duplicate-imports": "off",
    "max-statements": "off",
    "max-params": "off",
    "import/no-nodejs-modules": "off",
    "typescript/no-floating-promises": "error",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-unsafe-member-access": "warn",
    "typescript/no-unsafe-call": "warn",
    "typescript/no-misused-promises": [
      "error",
      {
        "checksVoidReturn": {
          "attributes": false
        }
      }
    ],
    "typescript/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "typescript/no-explicit-any": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.test.{ts,tsx,js,jsx}", "**/*.spec.{ts,tsx,js,jsx}"],
      "rules": {
        "no-console": "off",
        "vitest/prefer-describe-function-title": "off",
        "jest/prefer-importing-jest-globals": "off",
        "vitest/prefer-importing-vitest-globals": "off",
        "vitest/no-importing-vitest-globals": "off"
      }
    },
    {
      "files": ["**/api/**/route.ts", "**/app/**/page.tsx"],
      "rules": {
        "import/group-exports": "off"
      }
    },
    {
      "files": ["**/packages/chess/src/engine.ts"],
      "rules": {
        "promise/avoid-new": "off",
        "unicorn/require-post-message-target-origin": "off"
      }
    },
    {
      "files": ["**/apps/web/lib/services/engine.service.ts"],
      "rules": {
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-type-assertion": "off",
        "new-cap": "off"
      }
    },
    {
      "files": ["**/apps/web/lib/hooks/use-stockfish.ts"],
      "rules": {
        "typescript/no-unsafe-type-assertion": "off"
      }
    },
    {
      "files": ["**/convex/**/*.ts"],
      "rules": {
        "@convex-dev/import-wrong-runtime": "off",
        "@convex-dev/no-old-registered-function-syntax": "error",
        "@convex-dev/require-args-validator": "error",
        "@convex-dev/explicit-table-ids": "error",
        "unicorn/filename-case": "off"
      }
    },
    {
      "files": [
        "**/apps/web/convex/lichess_explorer.ts",
        "**/apps/web/convex/lichess_explorer_cache.ts"
      ],
      "rules": {
        "no-await-in-loop": "off"
      }
    },
    {
      "files": ["**/apps/web/lib/lichess/fetch-opening-explorer.ts"],
      "rules": {
        "no-await-in-loop": "off",
        "no-continue": "off"
      }
    },
    {
      "files": [
        "**/apps/web/lib/hooks/use-game-analysis.ts",
        "**/apps/web/lib/run-game-analysis.ts"
      ],
      "rules": {
        "no-await-in-loop": "off"
      }
    },
    {
      "files": ["**/apps/web/components/game/player-strip.tsx"],
      "rules": {
        "react/no-array-index-key": "off"
      }
    },
    {
      "files": ["**/apps/web/components/ai-elements/**/*.tsx"],
      "rules": {
        "import/exports-last": "off",
        "import/group-exports": "off",
        "react/no-array-index-key": "off"
      }
    }
  ]
}
