{
  "name": "@repo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "doppler run --project chess-studio --config ${DOPPLER_CONFIG:-dev} -- next dev",
    "build": "doppler run --project chess-studio --config ${DOPPLER_CONFIG:-dev} -- sh -c 'export NODE_ENV=production && next build'",
    "vercel:build": "NODE_ENV=production next build",
    "build:vercel": "pnpm run vercel:build",
    "start": "doppler run --project chess-studio --config ${DOPPLER_CONFIG:-dev} -- next start",
    "lint": "eslint .",
    "type-check": "tsgo --noEmit --project tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:generate": "doppler run --project chess-studio --config ${DOPPLER_CONFIG:-dev} -- pnpm dlx @better-auth/cli@1.4.19 generate",
    "setup:stockfish": "./scripts/setup-stockfish.sh",
    "postinstall": "pnpm setup:stockfish",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "vercel-build": "pnpm run vercel:build"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.87",
    "@base-ui/react": "^1.3.0",
    "@convex-dev/better-auth": "^0.10.11",
    "@hookform/resolvers": "^5.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@vercel/oidc": "^3.2.0",
    "ai": "^6.0.145",
    "better-auth": "^1.4.19",
    "chess.js": "^1.0.0-beta.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "lucide-react": "^0.575.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-chessboard": "^4.6.0",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "shadcn": "^3.8.5",
    "stockfish": "^17.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.19",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
