{
  "extends": "../../packages/config/typescript/nextjs.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"],
      "@repo/types": ["../../packages/types/src/index.ts"],
      "@repo/types/*": ["../../packages/types/src/*"],
      "@repo/chess": ["../../packages/chess/src/index.ts"],
      "@repo/chess/*": ["../../packages/chess/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", ".next", "**/convex/_generated/**"],
  "references": [
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/chess"
    }
  ]
}
