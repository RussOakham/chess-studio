# Next.js Web App Environment Variables

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication (Better Auth - to be configured)
# BETTER_AUTH_SECRET=your_secret_here
# BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth — duplicate these into Convex (auth runs there; otherwise sign-in returns PROVIDER_NOT_FOUND):
#   npx convex env set GITHUB_CLIENT_ID "..."
#   npx convex env set GITHUB_CLIENT_SECRET "..."
# NEXT_PUBLIC_GITHUB_AUTH_ENABLED=true
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# API Endpoints
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Feature Flags
# NEXT_PUBLIC_ENABLE_3D_BOARD=false
